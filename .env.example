PGHOST=localhost
PGPORT=5433
PGDATABASE=giga4dqm
PGUSER=your_user
PGPASSWORD=your_password
GIGACHAT_API_KEY=your_gigachat_api_key
GIGACHAT_EMBEDDINGS_CREDENTIALS=
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_VERIFY_SSL=false
GIGACHAT_SCOPE=GIGACHAT_API_PERS
MODEL=GigaChat-Pro
GIGACHAT_TIMEOUT=120
# Optional: Langfuse Cloud (EU) — keys from project settings in https://cloud.langfuse.com (e.g. project giga4dqm / org Sber).
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# Optional: LANGFUSE_TRACING_ENVIRONMENT=dev
# Optional: raise if TLS handshake to api/oauth hosts is slow (ConnectTimeout). Read/response still uses GIGACHAT_TIMEOUT.
# GIGACHAT_CONNECT_TIMEOUT=180
